# .env.example  (and copy to .env) 
DB_HOST=127.0.0.1 
DB_PORT=3306 
DB_NAME=books_api 
DB_USER=root 
DB_PASS= 
DB_CHARSET=utf8mb4 
DB_SSL=false
APP_DEBUG=true 

# JWT 
JWT_SECRET=change-me-to-a-long-random-string 
JWT_TTL=3600 
JWT_ISSUER=books-api 

# CORS (comma-separated origins, or * for any) 
CORS_ALLOWED_ORIGINS=* 

# Rate limiting 
LOGIN_RATE_LIMIT=5 
LOGIN_WINDOW_SECONDS=60 